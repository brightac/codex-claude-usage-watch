#!/usr/bin/env node

// Unified live view of Codex + Claude Code rate-limit windows (5h + weekly),
// auto-refreshing. Combines:
//   - Codex:  live app-server  account/rateLimits/read  (JSON-RPC over stdio)
//   - Claude: GET /api/oauth/usage  (keychain OAuth, auto-refresh)
//
// Both sources are fetched independently and fault-tolerantly: if one is
// unavailable, the other is still shown.
//
// Flags:  --once   single snapshot
//         -i N     refresh every N seconds (default 60)
//         --line   compact one-line summary (single-shot unless -i given)

const { spawn, spawnSync } = require("child_process");
const fs = require("fs");
const os = require("os");
const path = require("path");

// Persist last-good readings across process restarts so a throttled `--once`
// (this usage endpoint is aggressively rate-limited) shows slightly-stale data
// instead of "unavailable".
const CACHE_DIR = path.join(
  process.env.XDG_CACHE_HOME || path.join(os.homedir(), ".cache"),
  "usage-watch",
);
function cacheFile(name) {
  return path.join(CACHE_DIR, `${name}.json`);
}
function saveCache(name, value) {
  try {
    fs.mkdirSync(CACHE_DIR, { recursive: true });
    fs.writeFileSync(cacheFile(name), JSON.stringify({ value, at: Date.now() }));
  } catch {}
}
function loadCache(name) {
  try {
    return JSON.parse(fs.readFileSync(cacheFile(name), "utf8"));
  } catch {
    return null;
  }
}

const intervalArgIndex = process.argv.findIndex(
  (arg) => arg === "--interval" || arg === "-i",
);
const once = process.argv.includes("--once");
const lineMode = process.argv.includes("--line") || process.argv.includes("--oneline");
const jsonMode = process.argv.includes("--json");
const intervalSeconds =
  intervalArgIndex >= 0 && process.argv[intervalArgIndex + 1]
    ? Number(process.argv[intervalArgIndex + 1])
    : 300;

// ===========================================================================
// Shared formatting helpers
// ===========================================================================

function formatTime(epochSeconds) {
  return new Date(epochSeconds * 1000).toLocaleTimeString([], {
    hour: "2-digit",
    minute: "2-digit",
  });
}

function formatDateTime(epochSeconds) {
  return new Date(epochSeconds * 1000).toLocaleString([], {
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
}

function formatDuration(seconds) {
  if (seconds == null) return "unknown";
  let remaining = Math.max(0, Math.floor(seconds));
  const days = Math.floor(remaining / 86400);
  remaining %= 86400;
  const hours = Math.floor(remaining / 3600);
  remaining %= 3600;
  const minutes = Math.floor(remaining / 60);
  if (days > 0) return `${days}d ${hours}h ${minutes}m`;
  return `${hours}h ${minutes}m`;
}

// Fixed-width duration so the d/h/m columns line up across rows. Leading
// zero units are blanked, and each unit is right-aligned:
//   6d 20h 19m  ->  " 6d 20h 19m"
//   1h 19m      ->  "     1h 19m"
function formatDurationPad(seconds) {
  if (seconds == null) return "unknown".padStart(11);
  let remaining = Math.max(0, Math.floor(seconds));
  const days = Math.floor(remaining / 86400);
  remaining %= 86400;
  const hours = Math.floor(remaining / 3600);
  remaining %= 3600;
  const minutes = Math.floor(remaining / 60);
  const d = days > 0 ? `${days}d` : "";
  const h = days > 0 || hours > 0 ? `${hours}h` : "";
  const m = `${minutes}m`;
  return `${d.padStart(3)} ${h.padStart(3)} ${m.padStart(3)}`;
}

function bar(percent) {
  const width = 12;
  const p = Math.min(100, Math.max(0, percent));
  const filled = Math.round((p / 100) * width);
  return `[${"█".repeat(filled)}${"░".repeat(width - filled)}]`;
}

function titleCase(s) {
  return s ? s.charAt(0).toUpperCase() + s.slice(1) : s;
}
// Human plan label. Claude's rateLimitTier encodes the multiplier
// ("default_claude_max_20x" -> "Max 20×"); Codex only exposes planType.
function planLabel(name, plan, tier) {
  if (name === "Claude" && tier) {
    const parts = tier.replace(/^default_/, "").replace(/^claude_/, "").split("_").filter(Boolean);
    if (parts.length) {
      return parts.map((p) => (/^\d+x$/i.test(p) ? p.replace(/x$/i, "×") : titleCase(p))).join(" ");
    }
  }
  return titleCase(plan || "unknown");
}

function pct(n) {
  return `${Math.round(n * 10) / 10}%`;
}

// Right-align a percentage to a fixed width so columns line up
// ("9%" -> "   9%", "56%" -> "  56%", "100%" -> " 100%", "18.7%" -> "18.7%").
function pctPad(n) {
  return pct(n).padStart(5);
}

// ===========================================================================
// Codex source (live app-server JSON-RPC)
// ===========================================================================

function codexBin() {
  return (
    process.env.CODEX_BIN ||
    "/Applications/ChatGPT.app/Contents/Resources/codex"
  );
}

function readCodexRateLimits() {
  return new Promise((resolve, reject) => {
    let child;
    try {
      child = spawn(codexBin(), ["app-server", "--stdio"], {
        stdio: ["pipe", "pipe", "pipe"],
        env: process.env,
      });
    } catch (e) {
      reject(e);
      return;
    }

    let buffer = "";
    let settled = false;
    let initialized = false;

    const timer = setTimeout(() => {
      finish(new Error("timed out waiting for codex app-server"));
    }, 15000);

    function finish(error, value) {
      if (settled) return;
      settled = true;
      clearTimeout(timer);
      try { child.stdin.destroy(); } catch {}
      try { child.kill(); } catch {}
      if (error) reject(error);
      else resolve(value);
    }

    child.on("error", finish);
    child.stderr.on("data", () => {});

    child.stdout.on("data", (chunk) => {
      buffer += chunk.toString("utf8");
      for (;;) {
        const nl = buffer.indexOf("\n");
        if (nl < 0) break;
        const line = buffer.slice(0, nl).trim();
        buffer = buffer.slice(nl + 1);
        if (!line) continue;

        let message;
        try { message = JSON.parse(line); } catch { continue; }

        if (message.id === 1 && message.result && !initialized) {
          initialized = true;
          child.stdin.write(JSON.stringify({
            jsonrpc: "2.0", id: 2,
            method: "account/rateLimits/read", params: null,
          }) + "\n");
          continue;
        }
        if (message.id === 2) {
          if (message.error) finish(new Error(JSON.stringify(message.error)));
          else finish(null, message.result);
        }
      }
    });

    child.stdin.write(JSON.stringify({
      jsonrpc: "2.0", id: 1, method: "initialize",
      params: {
        clientInfo: { name: "usage-watch", title: null, version: "0.1.0" },
        capabilities: null,
      },
    }) + "\n");
  });
}

function normalizeCodexWindow(window) {
  if (!window) return null;
  const usedPercent = window.usedPercent ?? 0;
  return {
    usedPercent,
    remainingPercent: Math.max(0, 100 - usedPercent),
    resetsAt: window.resetsAt,
    windowMinutes: window.windowDurationMins ?? null,
    secondsLeft: window.resetsAt ? window.resetsAt - Date.now() / 1000 : null,
  };
}

// Label a Codex window by its ACTUAL duration, not its primary/secondary slot.
// (Codex dropped the 5h limit for some plans, so `primary` may now be the
// weekly window — hardcoding primary→5h mislabeled the weekly data as "5h".)
function codexWindowLabel(mins) {
  if (mins === 300) return "5h";
  if (mins === 10080) return "7d";
  if (mins && mins % 1440 === 0) return `${mins / 1440}d`;
  if (mins) return `${Math.round(mins / 60)}h`;
  return "?";
}

function normalizeCodex(result) {
  const snapshot =
    result.rateLimitsByLimitId?.codex ??
    result.rateLimits ??
    Object.values(result.rateLimitsByLimitId || {})[0];
  if (!snapshot) throw new Error("no codex rate limit snapshot");
  const windows = [];
  for (const raw of [snapshot.primary, snapshot.secondary]) {
    const w = normalizeCodexWindow(raw);
    if (w) windows.push({ label: codexWindowLabel(w.windowMinutes), ...w });
  }
  return {
    planType: snapshot.planType ?? result.rateLimits?.planType ?? "unknown",
    windows,
    resetCredits: result.rateLimitResetCredits?.availableCount,
  };
}

async function getCodex() {
  // The app-server occasionally fails to answer on first spawn; a fresh retry
  // almost always succeeds (normal response is ~3s), so retry before giving up.
  let lastErr;
  for (let attempt = 0; attempt < 3; attempt++) {
    try {
      return normalizeCodex(await readCodexRateLimits());
    } catch (e) {
      lastErr = e;
    }
  }
  throw lastErr;
}

// Keep the last successful reading so a transient failure (throttling, a
// dropped app-server, a network blip) shows slightly-stale data instead of
// "unavailable". "login" errors are never masked — those need real action.
function withCache(name, store, fn) {
  return async () => {
    try {
      const value = await fn();
      store.value = value;
      store.at = Date.now();
      saveCache(name, value);
      return value;
    } catch (e) {
      if (process.env.UW_DEBUG) console.error(`[${name}] fetch failed:`, e.message);
      if (e.message === "login") throw e; // real auth problem — never mask it
      const src = store.value ? { value: store.value, at: store.at } : loadCache(name);
      if (src && src.value) {
        return { ...src.value, staleSec: Math.round((Date.now() - src.at) / 1000) };
      }
      throw e;
    }
  };
}
const codexStore = {};
const claudeStore = {};
const getCodexCached = withCache("codex", codexStore, getCodex);

// ===========================================================================
// Claude source (keychain OAuth + /api/oauth/usage)
// ===========================================================================

const KC_SERVICE = "Claude Code-credentials";
const KC_ACCOUNT = process.env.USER || os.userInfo().username;
const CLAUDE_BASE = (process.env.ANTHROPIC_BASE_URL || "https://api.anthropic.com").replace(/\/$/, "");
const OAUTH_TOKEN_URL = "https://console.anthropic.com/v1/oauth/token";
const OAUTH_CLIENT_ID = "9d1c250a-e61b-44d9-88ed-5944d1962f5e";

function readClaudeKeychain() {
  const out = spawnSync("security",
    ["find-generic-password", "-s", KC_SERVICE, "-a", KC_ACCOUNT, "-w"],
    { encoding: "utf8" });
  if (out.status !== 0 || !out.stdout.trim()) return null;
  try { return JSON.parse(out.stdout); } catch { return null; }
}

function writeClaudeKeychain(full) {
  spawnSync("security",
    ["add-generic-password", "-U", "-s", KC_SERVICE, "-a", KC_ACCOUNT, "-w", JSON.stringify(full)],
    { encoding: "utf8" });
}

async function claudeRefresh(full) {
  const oauth = full.claudeAiOauth || {};
  if (!oauth.refreshToken) throw new Error("login"); // no refresh token -> re-auth needed
  const resp = await fetch(OAUTH_TOKEN_URL, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      grant_type: "refresh_token",
      refresh_token: oauth.refreshToken,
      client_id: OAUTH_CLIENT_ID,
    }),
  });
  if (!resp.ok) {
    // 400/401/403 = the stored refresh token is invalid/expired → re-auth
    // needed (common on a machine that only ever used the Claude desktop app).
    if ([400, 401, 403].includes(resp.status)) throw new Error("login");
    throw new Error(`refresh HTTP ${resp.status}`);
  }
  const data = await resp.json();
  if (!data.access_token) throw new Error("refresh missing token");
  oauth.accessToken = data.access_token;
  if (data.refresh_token) oauth.refreshToken = data.refresh_token;
  if (data.expires_in) oauth.expiresAt = Date.now() + data.expires_in * 1000;
  full.claudeAiOauth = oauth;
  writeClaudeKeychain(full);
  return oauth;
}

async function claudeToken() {
  const full = readClaudeKeychain();
  if (!full || !full.claudeAiOauth) throw new Error("login");
  const oauth = full.claudeAiOauth;
  const valid = (Number(oauth.expiresAt) || 0) - Date.now() > 60_000;
  if (valid && oauth.accessToken) return oauth;
  return await claudeRefresh(full);
}

function normalizeClaudeWindow(win, windowMinutes) {
  if (!win || win.utilization == null) return null;
  // `utilization` is already a 0..100 percentage (verified: 2.0 = 2% used).
  const util = win.utilization;
  let resetSec = null;
  const r = win.resets_at;
  if (typeof r === "number") resetSec = r > 1e12 ? r / 1000 : r;
  else if (typeof r === "string") {
    const p = Date.parse(r);
    if (!Number.isNaN(p)) resetSec = p / 1000;
  }
  return {
    usedPercent: Math.round(util * 10) / 10,
    resetsAt: resetSec,
    windowMinutes: windowMinutes ?? null,
    secondsLeft: resetSec != null ? resetSec - Date.now() / 1000 : null,
  };
}

async function getClaude() {
  const oauth = await claudeToken();
  const resp = await fetch(`${CLAUDE_BASE}/api/oauth/usage`, {
    headers: {
      Authorization: `Bearer ${oauth.accessToken}`,
      "anthropic-beta": "oauth-2025-04-20",
      "anthropic-version": "2023-06-01",
      "User-Agent": "usage-watch",
      Accept: "application/json",
    },
  });
  const text = await resp.text();
  if (resp.status === 401) throw new Error("login");
  if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
  const data = JSON.parse(text);
  const rl = data.rate_limits || data.rateLimits || data || {};
  return {
    planType: oauth.subscriptionType || "unknown",
    tier: oauth.rateLimitTier || "",
    five_hour: normalizeClaudeWindow(rl.five_hour, 300),
    seven_day: normalizeClaudeWindow(rl.seven_day, 10080),
    seven_day_opus: normalizeClaudeWindow(rl.seven_day_opus, 10080),
    seven_day_sonnet: normalizeClaudeWindow(rl.seven_day_sonnet, 10080),
  };
}
const getClaudeCached = withCache("claude", claudeStore, getClaude);

// ===========================================================================
// Rendering
// ===========================================================================

function leftOf(resetsAt) {
  return resetsAt ? resetsAt - Date.now() / 1000 : null;
}

// One consistent "↻ <when> (<left>)" column: same date+time format for every
// window, padded to a fixed width so the "(remaining)" part lines up.
function resetMark(resetsAt) {
  if (!resetsAt) return "";
  return `  ↻ ${formatDateTime(resetsAt).padEnd(16)} (${formatDurationPad(leftOf(resetsAt))})`;
}
function formatAge(sec) {
  sec = Math.max(0, Math.floor(sec));
  if (sec < 60) return "<1m ago";
  const m = Math.floor(sec / 60);
  if (m < 60) return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24) return `${h}h ${m % 60}m ago`;
  return `${Math.floor(h / 24)}d ${h % 24}h ago`;
}
function staleTag(c) {
  return c.staleSec != null ? `  (cached ${formatAge(c.staleSec)})` : "";
}

// Each section resolves to { error } OR { header, rows, extra }, where a row
// is { label, used, left, resetsAt }. Actual text is produced later by
// renderSection() using one global label width so every bar/column lines up
// across BOTH providers.
function codexSection(res) {
  if (res.status === "rejected") {
    const msg = res.reason?.message || String(res.reason);
    return { error: `Codex   | unavailable (${msg})` };
  }
  const c = res.value;
  const rows = (c.windows || []).map((w) => ({
    label: w.label, used: w.usedPercent, left: w.remainingPercent, resetsAt: w.resetsAt,
  }));
  return { header: `Codex   | ${planLabel("Codex", c.planType)}${staleTag(c)}`, rows, extra: [] };
}

function claudeSection(res) {
  if (res.status === "rejected") {
    const msg = res.reason?.message || String(res.reason);
    return { error: msg === "login"
      ? "Claude  | not logged in  ->  run: claude auth login  (NOT setup-token)"
      : `Claude  | unavailable (${msg})` };
  }
  const c = res.value;
  const defs = [
    ["5h", c.five_hour],
    ["7d", c.seven_day],
    ["7d Opus", c.seven_day_opus],
    ["7d Sonnet", c.seven_day_sonnet],
  ];
  const rows = [];
  for (const [label, win] of defs) {
    if (!win) continue;
    rows.push({ label, used: win.usedPercent, left: Math.max(0, 100 - win.usedPercent), resetsAt: win.resetsAt });
  }
  return { header: `Claude  | ${planLabel("Claude", c.planType, c.tier)}${staleTag(c)}`, rows, extra: [] };
}

function renderSection(sec, labelW) {
  if (sec.error) return [sec.error];
  const lines = [sec.header];
  for (const r of sec.rows) {
    // Fuel gauge: the bar shows what's LEFT (full = plenty), and we print the
    // remaining percentage only — that's all the user wants to know.
    lines.push(`  ${r.label.padEnd(labelW)}  ${bar(r.left)}  left ${pctPad(r.left)}${resetMark(r.resetsAt)}`);
  }
  lines.push(...sec.extra);
  return lines;
}

async function buildFullFrame() {
  const [codex, claude] = await Promise.allSettled([getCodexCached(), getClaudeCached()]);
  const cx = codexSection(codex);
  const cl = claudeSection(claude);
  const allRows = [...(cx.rows || []), ...(cl.rows || [])];
  const labelW = Math.max(2, ...allRows.map((r) => r.label.length));
  return [
    `Usage windows  |  ${new Date().toLocaleString()}`,
    "",
    ...renderSection(cx, labelW),
    "",
    ...renderSection(cl, labelW),
  ].join("\n");
}

// Structured output for the desktop HUD (dial skin needs exact numbers +
// reset timestamps + window durations to draw and animate).
async function buildJson() {
  const [codex, claude] = await Promise.allSettled([getCodexCached(), getClaudeCached()]);
  const providers = [];

  if (codex.status === "fulfilled") {
    const c = codex.value;
    const windows = (c.windows || []).map((w) => ({
      label: w.label, leftPercent: w.remainingPercent, resetsAt: w.resetsAt, windowMinutes: w.windowMinutes,
    }));
    providers.push({ name: "Codex", plan: c.planType, planLabel: planLabel("Codex", c.planType), staleSec: c.staleSec ?? null, windows });
  } else {
    providers.push({ name: "Codex", error: codex.reason?.message || "unavailable", windows: [] });
  }

  if (claude.status === "fulfilled") {
    const c = claude.value;
    const windows = [];
    const add = (label, w) => {
      if (w) windows.push({ label, leftPercent: Math.max(0, 100 - w.usedPercent), resetsAt: w.resetsAt, windowMinutes: w.windowMinutes });
    };
    add("5h", c.five_hour);
    add("7d", c.seven_day);
    add("7d Opus", c.seven_day_opus);
    add("7d Sonnet", c.seven_day_sonnet);
    providers.push({ name: "Claude", plan: c.planType, tier: c.tier, planLabel: planLabel("Claude", c.planType, c.tier), staleSec: c.staleSec ?? null, windows });
  } else {
    providers.push({ name: "Claude", error: claude.reason?.message || "unavailable", windows: [] });
  }

  return JSON.stringify({ fetchedAt: Date.now(), providers });
}

async function buildLine() {
  const [codex, claude] = await Promise.allSettled([getCodexCached(), getClaudeCached()]);
  const parts = [];

  // One-line mode also shows remaining ("left") to match the full view.
  if (codex.status === "fulfilled") {
    const c = codex.value;
    const seg = [];
    if (c.primary) seg.push(`5h ${pct(c.primary.remainingPercent)}`);
    if (c.secondary) seg.push(`7d ${pct(c.secondary.remainingPercent)}`);
    parts.push(`Codex ${seg.join(" ")}`.trim());
  } else {
    parts.push("Codex n/a");
  }

  if (claude.status === "fulfilled") {
    const c = claude.value;
    const seg = [];
    if (c.five_hour) seg.push(`5h ${pct(Math.max(0, 100 - c.five_hour.usedPercent))}`);
    if (c.seven_day) seg.push(`7d ${pct(Math.max(0, 100 - c.seven_day.usedPercent))}`);
    parts.push(`Claude ${seg.join(" ")}`.trim());
  } else {
    parts.push(claude.reason?.message === "login" ? "Claude login" : "Claude n/a");
  }

  return parts.join("  ‖  ");
}

// In-place, flicker-free redraw: home the cursor, overwrite, erase below.
// No full reset (\x1Bc), so nothing gets pushed into scrollback.
let firstFrame = true;
function paintFull(frame) {
  const home = firstFrame ? "\x1B[2J\x1B[3J\x1B[H" : "\x1B[H";
  firstFrame = false;
  process.stdout.write(`${home}${frame}\x1B[J`);
}
function paintLine(line) {
  // Stay on one row: carriage-return + clear-line, no newline.
  process.stdout.write(`\r\x1B[2K${line}`);
}

async function main() {
  if (jsonMode) {
    console.log(await buildJson());
    return;
  }
  if (lineMode) {
    if (intervalArgIndex < 0 || once) {
      console.log(await buildLine());
      return;
    }
    paintLine(await buildLine());
    setInterval(async () => {
      try { paintLine(await buildLine()); } catch (e) { paintLine(`error: ${e.message || e}`); }
    }, Math.max(1, intervalSeconds) * 1000);
    process.on("SIGINT", () => { process.stdout.write("\n"); process.exit(0); });
    return;
  }

  if (once) {
    console.log(await buildFullFrame());
    return;
  }

  paintFull(await buildFullFrame());
  setInterval(async () => {
    try { paintFull(await buildFullFrame()); } catch (e) { paintFull(`error: ${e.message || e}`); }
  }, Math.max(1, intervalSeconds) * 1000);
}

main().catch((e) => {
  console.error(e.message || String(e));
  process.exit(1);
});
