#!/usr/bin/env node

const { spawn } = require("child_process");

const intervalArgIndex = process.argv.findIndex(
  (arg) => arg === "--interval" || arg === "-i",
);
const once = process.argv.includes("--once");
const jsonOutput = process.argv.includes("--json");
const intervalSeconds =
  intervalArgIndex >= 0 && process.argv[intervalArgIndex + 1]
    ? Number(process.argv[intervalArgIndex + 1])
    : 10;
const timeoutArgIndex = process.argv.findIndex(
  (arg) => arg === "--timeout" || arg === "-t",
);
const timeoutSeconds =
  timeoutArgIndex >= 0 && process.argv[timeoutArgIndex + 1]
    ? Number(process.argv[timeoutArgIndex + 1])
    : 45;

function codexBin() {
  return (
    process.env.CODEX_BIN ||
    "/Applications/ChatGPT.app/Contents/Resources/codex"
  );
}

function sendJson(child, message) {
  child.stdin.write(`${JSON.stringify(message)}\n`);
}

function readLiveRateLimits() {
  return new Promise((resolve, reject) => {
    const child = spawn(codexBin(), ["app-server", "--stdio"], {
      stdio: ["pipe", "pipe", "pipe"],
      env: process.env,
    });

    let buffer = "";
    let settled = false;
    let initialized = false;

    const timer = setTimeout(() => {
      finish(new Error("Timed out waiting for codex app-server rate limits"));
    }, Math.max(5, timeoutSeconds) * 1000);

    function finish(error, value) {
      if (settled) return;
      settled = true;
      clearTimeout(timer);
      child.stdin.destroy();
      child.kill();
      if (error) reject(error);
      else resolve(value);
    }

    child.on("error", finish);

    child.stderr.on("data", () => {
      // app-server may log plugin sync warnings on stderr; they are not relevant here.
    });

    child.stdout.on("data", (chunk) => {
      buffer += chunk.toString("utf8");

      for (;;) {
        const newlineIndex = buffer.indexOf("\n");
        if (newlineIndex < 0) break;

        const line = buffer.slice(0, newlineIndex).trim();
        buffer = buffer.slice(newlineIndex + 1);
        if (!line) continue;

        let message;
        try {
          message = JSON.parse(line);
        } catch {
          continue;
        }

        if (message.id === 1 && message.result && !initialized) {
          initialized = true;
          sendJson(child, {
            jsonrpc: "2.0",
            id: 2,
            method: "account/rateLimits/read",
            params: null,
          });
          continue;
        }

        if (message.id === 2) {
          if (message.error) {
            finish(new Error(JSON.stringify(message.error)));
          } else {
            finish(null, message.result);
          }
        }
      }
    });

    sendJson(child, {
      jsonrpc: "2.0",
      id: 1,
      method: "initialize",
      params: {
        clientInfo: {
          name: "codex-usage-watch",
          title: null,
          version: "0.2.0",
        },
        capabilities: null,
      },
    });
  });
}

function formatTime(epochSeconds) {
  return new Date(epochSeconds * 1000).toLocaleTimeString([], {
    hour: "2-digit",
    minute: "2-digit",
  });
}

function formatDate(epochSeconds) {
  return new Date(epochSeconds * 1000).toLocaleDateString([], {
    month: "short",
    day: "numeric",
  });
}

function formatDateTime(epochSeconds) {
  return new Date(epochSeconds * 1000).toLocaleString([], {
    month: "short",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
}

function formatDuration(seconds) {
  let remaining = Math.max(0, Math.floor(seconds));
  const days = Math.floor(remaining / 86400);
  remaining %= 86400;
  const hours = Math.floor(remaining / 3600);
  remaining %= 3600;
  const minutes = Math.floor(remaining / 60);

  if (days > 0) return `${days}d ${hours}h ${minutes}m`;
  return `${hours}h ${minutes}m`;
}

function normalizeWindow(window) {
  if (!window) return null;

  const usedPercent = window.usedPercent ?? 0;
  return {
    usedPercent,
    remainingPercent: Math.max(0, 100 - usedPercent),
    windowDurationMins: window.windowDurationMins,
    resetsAt: window.resetsAt,
    secondsLeft: window.resetsAt ? window.resetsAt - Date.now() / 1000 : null,
  };
}

function normalizeRateLimits(result) {
  const snapshot =
    result.rateLimitsByLimitId?.codex ??
    result.rateLimits ??
    Object.values(result.rateLimitsByLimitId || {})[0];

  if (!snapshot) {
    throw new Error("No codex rate limit snapshot returned by app-server");
  }

  return {
    planType: snapshot.planType ?? result.rateLimits?.planType ?? "unknown",
    primary: normalizeWindow(snapshot.primary),
    secondary: normalizeWindow(snapshot.secondary),
    credits: snapshot.credits,
    resetCredits: result.rateLimitResetCredits,
  };
}

function renderHuman(result) {
  const limits = normalizeRateLimits(result);

  console.log(`Codex usage windows | plan=${limits.planType}`);
  console.log(`Source: live app-server account/rateLimits/read`);
  console.log("");

  if (limits.primary) {
    console.log("5-hour usage limit");
    console.log(`    remaining: ${limits.primary.remainingPercent}%`);
    console.log(`    used:      ${limits.primary.usedPercent}%`);
    if (limits.primary.resetsAt) {
      console.log(`    resets:    ${formatTime(limits.primary.resetsAt)} (${formatDuration(limits.primary.secondsLeft)})`);
    }
  }

  if (limits.secondary) {
    console.log("");
    console.log("Weekly usage limit");
    console.log(`    remaining: ${limits.secondary.remainingPercent}%`);
    console.log(`    used:      ${limits.secondary.usedPercent}%`);
    if (limits.secondary.resetsAt) {
      console.log(`    resets:    ${formatDateTime(limits.secondary.resetsAt)} (${formatDuration(limits.secondary.secondsLeft)})`);
    }
  }

  const availableResetCredits = limits.resetCredits?.availableCount;
  if (typeof availableResetCredits === "number") {
    console.log("");
    console.log(`Reset credits: ${availableResetCredits}`);
  }
}

async function render() {
  if (!jsonOutput) {
    console.log("Fetching live Codex account rate limits...");
  }
  const result = await readLiveRateLimits();
  if (jsonOutput) {
    console.log(JSON.stringify(result, null, 2));
  } else {
    renderHuman(result);
  }
}

function clearScreen() {
  process.stdout.write("\x1Bc");
}

async function main() {
  if (once) {
    await render();
    return;
  }

  await render();
  setInterval(async () => {
    clearScreen();
    try {
      await render();
    } catch (error) {
      console.error(error.message || String(error));
    }
  }, Math.max(1, intervalSeconds) * 1000);
}

main().catch((error) => {
  console.error(error.message || String(error));
  process.exit(1);
});
