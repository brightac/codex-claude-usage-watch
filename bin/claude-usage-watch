#!/usr/bin/env node

// Live view of Claude Code rate-limit windows (5h + weekly), auto-refreshing.
// Mirrors ~/.local/bin/codex-usage-watch, but for Claude Code.
//
// Source of truth: GET https://api.anthropic.com/api/oauth/usage
// (the same endpoint the in-session `/usage` command uses).
// Auth comes from the Claude Code CLI's keychain OAuth entry
// ("Claude Code-credentials"); the token is refreshed automatically
// when it is expired, provided a refresh token is present.

const { spawnSync } = require("child_process");

const KEYCHAIN_SERVICE = "Claude Code-credentials";
const KEYCHAIN_ACCOUNT = process.env.USER || require("os").userInfo().username;
const BASE_URL = (process.env.ANTHROPIC_BASE_URL || "https://api.anthropic.com").replace(/\/$/, "");
const OAUTH_TOKEN_URL = "https://console.anthropic.com/v1/oauth/token";
const OAUTH_CLIENT_ID = "9d1c250a-e61b-44d9-88ed-5944d1962f5e";
const BETA_HEADER = "oauth-2025-04-20";

const intervalArgIndex = process.argv.findIndex(
  (arg) => arg === "--interval" || arg === "-i",
);
const once = process.argv.includes("--once");
const lineMode = process.argv.includes("--line") || process.argv.includes("--oneline");
const intervalSeconds =
  intervalArgIndex >= 0 && process.argv[intervalArgIndex + 1]
    ? Number(process.argv[intervalArgIndex + 1])
    : 60;

// ---------------------------------------------------------------------------
// Keychain access
// ---------------------------------------------------------------------------

function readKeychain() {
  const out = spawnSync(
    "security",
    ["find-generic-password", "-s", KEYCHAIN_SERVICE, "-a", KEYCHAIN_ACCOUNT, "-w"],
    { encoding: "utf8" },
  );
  if (out.status !== 0 || !out.stdout.trim()) return null;
  try {
    return JSON.parse(out.stdout);
  } catch {
    return null;
  }
}

function writeKeychain(fullObject) {
  // -U updates in place; keep the whole blob so mcpOAuth etc. survive.
  const res = spawnSync(
    "security",
    [
      "add-generic-password",
      "-U",
      "-s", KEYCHAIN_SERVICE,
      "-a", KEYCHAIN_ACCOUNT,
      "-w", JSON.stringify(fullObject),
    ],
    { encoding: "utf8" },
  );
  return res.status === 0;
}

// ---------------------------------------------------------------------------
// OAuth token handling
// ---------------------------------------------------------------------------

async function refreshToken(fullObject) {
  const oauth = fullObject.claudeAiOauth || {};
  if (!oauth.refreshToken) {
    return { error: "no-refresh-token" };
  }

  let resp;
  try {
    resp = await fetch(OAUTH_TOKEN_URL, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        grant_type: "refresh_token",
        refresh_token: oauth.refreshToken,
        client_id: OAUTH_CLIENT_ID,
      }),
    });
  } catch (e) {
    return { error: `refresh-network-error: ${e.message}` };
  }

  if (!resp.ok) {
    return { error: `refresh-failed: HTTP ${resp.status}` };
  }

  const data = await resp.json();
  if (!data.access_token) return { error: "refresh-missing-token" };

  oauth.accessToken = data.access_token;
  if (data.refresh_token) oauth.refreshToken = data.refresh_token;
  if (data.expires_in) oauth.expiresAt = Date.now() + data.expires_in * 1000;
  fullObject.claudeAiOauth = oauth;

  writeKeychain(fullObject); // best-effort; keep going even if it fails
  return { token: oauth.accessToken };
}

async function getAccessToken() {
  const full = readKeychain();
  if (!full || !full.claudeAiOauth) {
    return { error: "no-credentials" };
  }
  const oauth = full.claudeAiOauth;
  const expiresAt = Number(oauth.expiresAt) || 0;
  const stillValid = expiresAt - Date.now() > 60_000; // 60s safety margin

  if (stillValid && oauth.accessToken) {
    return { token: oauth.accessToken, meta: oauth };
  }
  const refreshed = await refreshToken(full);
  if (refreshed.error) return { ...refreshed, meta: oauth };
  return { token: refreshed.token, meta: full.claudeAiOauth };
}

// ---------------------------------------------------------------------------
// Usage endpoint
// ---------------------------------------------------------------------------

async function fetchUsage(token) {
  const resp = await fetch(`${BASE_URL}/api/oauth/usage`, {
    headers: {
      Authorization: `Bearer ${token}`,
      "anthropic-beta": BETA_HEADER,
      "anthropic-version": "2023-06-01",
      "User-Agent": "claude-usage-watch",
      Accept: "application/json",
    },
  });
  const body = await resp.text();
  if (!resp.ok) {
    return { error: `HTTP ${resp.status}`, body };
  }
  try {
    return { data: JSON.parse(body) };
  } catch {
    return { error: "unparseable-response", body };
  }
}

// ---------------------------------------------------------------------------
// Formatting
// ---------------------------------------------------------------------------

function normalizeWindow(win) {
  if (!win) return null;
  let util = win.utilization;
  if (util == null) return null;
  if (util <= 1) util *= 100; // API returns a 0..1 fraction

  let resetSec = null;
  const r = win.resets_at;
  if (typeof r === "number") {
    resetSec = r > 1e12 ? r / 1000 : r; // ms vs s
  } else if (typeof r === "string") {
    const parsed = Date.parse(r);
    if (!Number.isNaN(parsed)) resetSec = parsed / 1000;
  }
  const usedPercent = Math.round(util * 10) / 10;
  return { usedPercent, leftPercent: Math.round((100 - usedPercent) * 10) / 10, resetSec };
}

function findRateLimits(data) {
  return data && (data.rate_limits || data.rateLimits || data) || {};
}

function formatDate(epochSeconds) {
  if (epochSeconds == null) return "unknown";
  return new Date(epochSeconds * 1000).toLocaleString();
}

function formatDuration(seconds) {
  if (seconds == null) return "unknown";
  let remaining = Math.max(0, Math.floor(seconds));
  const days = Math.floor(remaining / 86400);
  remaining %= 86400;
  const hours = Math.floor(remaining / 3600);
  remaining %= 3600;
  const minutes = Math.floor(remaining / 60);
  const secs = remaining % 60;
  if (days > 0) return `${days}d ${hours}h ${minutes}m`;
  return `${hours}h ${minutes}m ${secs}s`;
}

function bar(percent) {
  const width = 12;
  const filled = Math.round(Math.min(100, Math.max(0, percent)) / 100 * width);
  return `[${"█".repeat(filled)}${"░".repeat(width - filled)}]`;
}

// ---------------------------------------------------------------------------
// Render
// ---------------------------------------------------------------------------

async function render() {
  const auth = await getAccessToken();

  if (auth.error === "no-credentials") {
    console.log("No Claude Code credentials found in the keychain.");
    console.log('Log in once with the CLI:  claude  (then /login),  or:  claude setup-token');
    return;
  }
  if (auth.error) {
    console.log(`Could not obtain a valid access token (${auth.error}).`);
    if (auth.error === "no-refresh-token") {
      console.log("The stored token is expired and has no refresh token.");
      console.log("Re-authenticate the CLI once:  claude  ->  /login   (or  claude setup-token )");
    }
    return;
  }

  const usage = await fetchUsage(auth.token);
  if (usage.error) {
    console.log(`Failed to fetch usage: ${usage.error}`);
    if (usage.error.startsWith("HTTP 401")) {
      console.log("Token was rejected. Re-authenticate the CLI:  claude  ->  /login");
    } else if (usage.body) {
      console.log(usage.body.slice(0, 300));
    }
    return;
  }

  const now = Date.now() / 1000;
  const plan = (auth.meta && auth.meta.subscriptionType) || "unknown";
  const tier = (auth.meta && auth.meta.rateLimitTier) || "";
  const rl = findRateLimits(usage.data);

  console.log(`Claude Code usage windows | plan=${plan}${tier ? ` tier=${tier}` : ""}`);
  console.log(`Fetched: ${new Date().toLocaleString()}`);
  console.log("");

  const windows = [
    ["5h  (session)", rl.five_hour],
    ["7d  (all models)", rl.seven_day],
    ["7d  (Opus)", rl.seven_day_opus],
    ["7d  (Sonnet)", rl.seven_day_sonnet],
  ];

  let printed = 0;
  for (const [name, raw] of windows) {
    const win = normalizeWindow(raw);
    if (!win) continue;
    printed++;
    const secondsLeft = win.resetSec != null ? win.resetSec - now : null;
    console.log(`${name}`);
    console.log(`    ${bar(win.leftPercent)} ${win.leftPercent}% left`);
    console.log(`    reset at:  ${formatDate(win.resetSec)}`);
    console.log(`    time left: ${formatDuration(secondsLeft)}`);
    console.log("");
  }

  if (printed === 0) {
    console.log("No rate-limit windows in the response. Raw payload:");
    console.log(JSON.stringify(usage.data, null, 2).slice(0, 800));
  }
}

// Compact one-line status of remaining quota, e.g.:  5h 75% · 7d 95%
async function lineString() {
  const auth = await getAccessToken();
  if (auth.error) {
    return auth.error === "no-credentials" || auth.error === "no-refresh-token"
      ? "usage: login"
      : "usage: n/a";
  }
  const usage = await fetchUsage(auth.token);
  if (usage.error) {
    return usage.error.startsWith("HTTP 401") ? "usage: login" : "usage: n/a";
  }

  const rl = findRateLimits(usage.data);
  const parts = [];
  const push = (label, raw) => {
    const win = normalizeWindow(raw);
    if (win) parts.push(`${label} ${win.leftPercent}%`);
  };
  push("5h", rl.five_hour);
  push("7d", rl.seven_day);
  push("Opus", rl.seven_day_opus);
  push("Sonnet", rl.seven_day_sonnet);

  return parts.length ? parts.join(" · ") : "usage: n/a";
}

async function renderLine() {
  console.log(await lineString());
}

// In-place redraw: home the cursor and overwrite, erasing leftover lines
// below. No \x1Bc full reset, so nothing is pushed into scrollback.
let firstFrame = true;
function homeCursor() {
  process.stdout.write(firstFrame ? "\x1B[2J\x1B[3J\x1B[H" : "\x1B[H");
  firstFrame = false;
}

async function main() {
  if (lineMode) {
    // Single-line mode is single-shot unless an explicit interval is given.
    if (intervalArgIndex < 0 || once) {
      await renderLine();
      return;
    }
    // Stay on one row: carriage-return + clear-line, no newline.
    const paint = async () => process.stdout.write(`\r\x1B[2K${await lineString()}`);
    await paint();
    setInterval(paint, Math.max(1, intervalSeconds) * 1000);
    process.on("SIGINT", () => { process.stdout.write("\n"); process.exit(0); });
    return;
  }
  if (once) {
    await render();
    return;
  }
  const loop = async () => {
    homeCursor();
    await render();
    process.stdout.write("\x1B[J");
  };
  await loop();
  setInterval(loop, Math.max(1, intervalSeconds) * 1000);
}

main();
